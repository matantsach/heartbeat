{
  "name": "heartbeat",
  "version": "0.1.0",
  "description": "Watchdog plugin that detects stuck, looping, or stalled agents and nudges them back on track.",
  "author": "Matan Tsach",
  "license": "MIT",
  "hooks": {
    "preToolUse": "./scripts/pre-tool-use.sh",
    "postToolUse": "./scripts/post-tool-use.sh",
